  .sc-body{font-size:11px;color:var(--text-muted);line-height:1.45;}
  .sc-rec{font-size:11px;color:var(--navy);font-weight:600;margin-top:5px;}

  #hint{font-family:'DM Mono';font-size:10px;color:rgba(255,255,255,0.2);letter-spacing:1px;}
